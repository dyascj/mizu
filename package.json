{
	"name": "mizu",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.28.2",
	"description": "A Frutiger Aero design system for Svelte. Glossy, glassy components for SvelteKit, Svelte 5, and Tailwind v4.",
	"keywords": [
		"svelte",
		"sveltekit",
		"tailwindcss",
		"design-system",
		"component-library",
		"ui",
		"frutiger-aero",
		"shadcn-svelte",
		"bits-ui"
	],
	"homepage": "https://github.com/dyascj/mizu#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dyascj/mizu.git"
	},
	"bugs": {
		"url": "https://github.com/dyascj/mizu/issues"
	},
	"author": "CJ Dyas",
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"registry:build": "node scripts/build-registry.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"phosphor-svelte": "^3.1.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"embla-carousel": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"paneforge": "^1.0.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2"
	}
}
