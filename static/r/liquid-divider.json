  "name": "liquid-divider",
  "type": "registry:ui",
  "title": "Liquid Divider",
  "description": "A separator that ripples like the surface of water.",
  "dependencies": [],
  "registryDependencies": [
    "https://mizu-ui.com/r/utils.json"
