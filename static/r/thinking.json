{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "thinking",
  "type": "registry:ui",
  "title": "Thinking",
  "description": "Shimmer and typing-dot indicators for a working assistant.",
  "dependencies": [],
  "registryDependencies": [
    "https://mizu-ui.com/r/utils.json"
  ],
  "files": [
    {
      "type": "registry:file",
      "target": "thinking/index.ts",
      "content": "export { default as Thinking } from './thinking.svelte';\n"
    },
    {
      "type": "registry:file",
      "target": "thinking/thinking.svelte",
      "content": "<script lang=\"ts\">\n\timport type { HTMLAttributes } from 'svelte/elements';\n\timport { cn } from '$lib/utils.js';\n\n\ttype Props = Omit<HTMLAttributes<HTMLDivElement>, 'children'> & {\n\t\tlabel?: string;\n\t\t/** shimmer sweeps light across the label; dots is the classic typing hint. */\n\t\tvariant?: 'shimmer' | 'dots';\n\t\tclass?: string;\n\t\tref?: HTMLDivElement | null;\n\t};\n\n\tlet {\n\t\tlabel = 'Thinking...',\n\t\tvariant = 'shimmer',\n\t\tclass: className,\n\t\tref = $bindable(null),\n\t\t...rest\n\t}: Props = $props();\n</script>\n\n<div\n\tbind:this={ref}\n\trole=\"status\"\n\taria-label={label}\n\tclass={cn('flex w-fit items-center gap-2 text-sm', className)}\n\t{...rest}\n>\n\t{#if variant === 'dots'}\n\t\t<span class=\"flex items-center gap-1\" aria-hidden=\"true\">\n\t\t\t<span class=\"thinking-dot size-1.5 rounded-full bg-muted-foreground\"></span>\n\t\t\t<span\n\t\t\t\tclass=\"thinking-dot size-1.5 rounded-full bg-muted-foreground\"\n\t\t\t\tstyle=\"animation-delay: 150ms;\"\n\t\t\t></span>\n\t\t\t<span\n\t\t\t\tclass=\"thinking-dot size-1.5 rounded-full bg-muted-foreground\"\n\t\t\t\tstyle=\"animation-delay: 300ms;\"\n\t\t\t></span>\n\t\t</span>\n\t\t<span class=\"text-muted-foreground\">{label}</span>\n\t{:else}\n\t\t<span class=\"thinking-shimmer\" aria-hidden=\"true\">{label}</span>\n\t{/if}\n</div>\n\n<style>\n\t.thinking-dot {\n\t\tanimation: thinking-bounce 1.2s ease-in-out infinite;\n\t}\n\n\t.thinking-shimmer {\n\t\tbackground: linear-gradient(\n\t\t\t90deg,\n\t\t\tvar(--muted-foreground) 0%,\n\t\t\tvar(--muted-foreground) 35%,\n\t\t\tvar(--foreground) 50%,\n\t\t\tvar(--muted-foreground) 65%,\n\t\t\tvar(--muted-foreground) 100%\n\t\t);\n\t\tbackground-size: 200% 100%;\n\t\t-webkit-background-clip: text;\n\t\tbackground-clip: text;\n\t\tcolor: transparent;\n\t\tanimation: thinking-sweep 2s linear infinite;\n\t}\n\n\t@keyframes thinking-bounce {\n\t\t0%,\n\t\t60%,\n\t\t100% {\n\t\t\ttransform: translateY(0);\n\t\t\topacity: 0.5;\n\t\t}\n\t\t30% {\n\t\t\ttransform: translateY(-3px);\n\t\t\topacity: 1;\n\t\t}\n\t}\n\n\t@keyframes thinking-sweep {\n\t\tfrom {\n\t\t\tbackground-position: 200% 0;\n\t\t}\n\t\tto {\n\t\t\tbackground-position: -200% 0;\n\t\t}\n\t}\n\n\t@media (prefers-reduced-motion: reduce) {\n\t\t.thinking-dot,\n\t\t.thinking-shimmer {\n\t\t\tanimation: none;\n\t\t}\n\t}\n</style>\n"
    }
  ]
