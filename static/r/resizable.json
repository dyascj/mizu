{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "resizable",
  "type": "registry:ui",
  "title": "Resizable",
  "description": "Draggable panes split by a glassy aqua handle.",
  "dependencies": [
    "@lucide/svelte",
    "paneforge"
  ],
  "registryDependencies": [
    "https://mizu-ui.com/r/utils.json"
  ],
  "files": [
    {
      "type": "registry:file",
      "target": "resizable/index.ts",
      "content": "import PaneGroup from './resizable-pane-group.svelte';\nimport Pane from './resizable-pane.svelte';\nimport Handle from './resizable-handle.svelte';\n\nexport {\n\tPaneGroup,\n\tPane,\n\tHandle,\n\t//\n\tPaneGroup as Root,\n\tPane as ResizablePane,\n\tHandle as ResizableHandle,\n\tPaneGroup as ResizablePaneGroup\n};\n"
    },
    {
      "type": "registry:file",
      "target": "resizable/resizable-handle.svelte",
      "content": "<script lang=\"ts\">\n\timport { PaneResizer, type PaneResizerProps } from 'paneforge';\n\timport GripVerticalIcon from '@lucide/svelte/icons/grip-vertical';\n\timport { cn } from '$lib/utils.js';\n\n\ttype Props = PaneResizerProps & {\n\t\twithHandle?: boolean;\n\t};\n\n\tlet { ref = $bindable(null), class: className, withHandle = false, ...rest }: Props = $props();\n</script>\n\n<PaneResizer\n\tbind:ref\n\tclass={cn(\n\t\t// A thin aqua-lit seam: neutral at rest, blooms to the brand accent on\n\t\t// hover / keyboard focus / active drag. `group` lets the inner grip react\n\t\t// to the resizer's data-direction.\n\t\t'group relative flex w-px items-center justify-center bg-border outline-none transition-colors duration-150 ease-out',\n\t\t'after:absolute after:inset-y-0 after:left-1/2 after:w-1 after:-translate-x-1/2',\n\t\t'hover:bg-[color:color-mix(in_oklab,var(--primary)_55%,transparent)]',\n\t\t'focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-1 focus-visible:ring-offset-background',\n\t\t'data-[active=pointer]:bg-primary data-[active=keyboard]:bg-primary',\n\t\t// Vertical pane group → the seam runs horizontally.\n\t\t'data-[direction=vertical]:h-px data-[direction=vertical]:w-full',\n\t\t'data-[direction=vertical]:after:inset-x-0 data-[direction=vertical]:after:left-0 data-[direction=vertical]:after:top-1/2 data-[direction=vertical]:after:h-1 data-[direction=vertical]:after:w-full data-[direction=vertical]:after:-translate-y-1/2 data-[direction=vertical]:after:translate-x-0',\n\t\tclassName\n\t)}\n\t{...rest}\n>\n\t{#if withHandle}\n\t\t<div\n\t\t\tclass=\"glass-strong gloss relative z-10 flex h-7 w-3.5 items-center justify-center overflow-hidden rounded-sm border border-[color:var(--glass-border)] shadow-bevel group-data-[direction=vertical]:h-3.5 group-data-[direction=vertical]:w-7\"\n\t\t>\n\t\t\t<GripVerticalIcon\n\t\t\t\tclass=\"relative z-10 size-3 text-muted-foreground group-data-[direction=vertical]:rotate-90\"\n\t\t\t/>\n\t\t</div>\n\t{/if}\n</PaneResizer>\n"
    },
    {
      "type": "registry:file",
      "target": "resizable/resizable-pane-group.svelte",
      "content": "<script lang=\"ts\">\n\timport { PaneGroup, type PaneGroupProps } from 'paneforge';\n\timport { cn } from '$lib/utils.js';\n\n\tlet { ref = $bindable(null), class: className, ...rest }: PaneGroupProps = $props();\n</script>\n\n<PaneGroup\n\tbind:ref\n\tclass={cn('flex h-full w-full data-[direction=vertical]:flex-col', className)}\n\t{...rest}\n/>\n"
    },
    {
      "type": "registry:file",
      "target": "resizable/resizable-pane.svelte",
      "content": "<script lang=\"ts\">\n\timport { Pane, type PaneProps } from 'paneforge';\n\n\tlet { ref = $bindable(null), ...rest }: PaneProps = $props();\n</script>\n\n<Pane bind:ref {...rest} />\n"
    }
  ]
}
