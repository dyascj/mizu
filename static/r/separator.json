{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "separator",
  "type": "registry:ui",
  "title": "Separator",
  "description": "A hairline divider for sections.",
  "dependencies": [],
  "registryDependencies": [
    "utils"
  ],
  "files": [
    {
      "path": "lib/components/ui/separator/index.ts",
      "type": "registry:ui",
      "target": "src/lib/components/ui/separator/index.ts",
      "content": "export { default as Separator } from './separator.svelte';\n"
    },
    {
      "path": "lib/components/ui/separator/separator.svelte",
      "type": "registry:ui",
      "target": "src/lib/components/ui/separator/separator.svelte",
      "content": "<script lang=\"ts\">\n\timport type { HTMLAttributes } from 'svelte/elements';\n\timport { cn } from '$lib/utils.js';\n\n\ttype Props = HTMLAttributes<HTMLDivElement> & {\n\t\tclass?: string;\n\t\torientation?: 'horizontal' | 'vertical';\n\t\tdecorative?: boolean;\n\t};\n\tlet {\n\t\tclass: className,\n\t\torientation = 'horizontal',\n\t\tdecorative = true,\n\t\t...rest\n\t}: Props = $props();\n</script>\n\n<div\n\trole={decorative ? 'none' : 'separator'}\n\taria-orientation={decorative ? undefined : orientation}\n\tclass={cn(\n\t\t'shrink-0 bg-border',\n\t\torientation === 'horizontal' ? 'h-px w-full' : 'h-full w-px',\n\t\tclassName\n\t)}\n\t{...rest}\n></div>\n"
    }
  ]
}
