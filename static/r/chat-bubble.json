{
  "$schema": "https://shadcn-svelte.com/schema/registry-item.json",
  "name": "chat-bubble",
  "type": "registry:ui",
  "title": "Chat Bubble",
  "description": "User and assistant message bubbles, flat and quiet.",
  "dependencies": [
    "tailwind-variants"
  ],
  "registryDependencies": [
    "https://mizu-ui.com/r/utils.json"
  ],
  "files": [
    {
      "type": "registry:file",
      "target": "chat-bubble/chat-bubble.svelte",
      "content": "<script lang=\"ts\" module>\n\timport { tv, type VariantProps } from 'tailwind-variants';\n\n\texport const chatBubbleVariants = tv({\n\t\tbase: 'w-fit max-w-[85%] rounded-2xl px-4 py-2.5 text-sm leading-relaxed break-words',\n\t\tvariants: {\n\t\t\trole: {\n\t\t\t\tuser: 'ml-auto rounded-br-md bg-primary text-primary-foreground',\n\t\t\t\tassistant: 'mr-auto rounded-bl-md bg-secondary text-foreground'\n\t\t\t}\n\t\t},\n\t\tdefaultVariants: { role: 'assistant' }\n\t});\n\n\texport type ChatBubbleRole = VariantProps<typeof chatBubbleVariants>['role'];\n</script>\n\n<script lang=\"ts\">\n\timport type { Snippet } from 'svelte';\n\timport type { HTMLAttributes } from 'svelte/elements';\n\timport { cn } from '$lib/utils.js';\n\n\ttype Props = HTMLAttributes<HTMLDivElement> & {\n\t\trole?: ChatBubbleRole;\n\t\t/** Rise-and-fade entrance as the message arrives. */\n\t\tanimate?: boolean;\n\t\tclass?: string;\n\t\tref?: HTMLDivElement | null;\n\t\tchildren?: Snippet;\n\t};\n\n\tlet {\n\t\trole = 'assistant',\n\t\tanimate = true,\n\t\tclass: className,\n\t\tref = $bindable(null),\n\t\tchildren,\n\t\t...rest\n\t}: Props = $props();\n</script>\n\n<div\n\tbind:this={ref}\n\tclass={cn(chatBubbleVariants({ role }), animate && 'bubble-in', className)}\n\t{...rest}\n>\n\t{@render children?.()}\n</div>\n\n<style>\n\t:global(.bubble-in) {\n\t\tanimation: bubble-in 220ms ease-out both;\n\t}\n\n\t@keyframes bubble-in {\n\t\tfrom {\n\t\t\topacity: 0;\n\t\t\ttransform: translateY(4px);\n\t\t}\n\t\tto {\n\t\t\topacity: 1;\n\t\t\ttransform: translateY(0);\n\t\t}\n\t}\n\n\t@media (prefers-reduced-motion: reduce) {\n\t\t:global(.bubble-in) {\n\t\t\tanimation: none;\n\t\t}\n\t}\n</style>\n"
    },
    {
      "type": "registry:file",
      "target": "chat-bubble/index.ts",
      "content": "export { default as ChatBubble } from './chat-bubble.svelte';\nexport { chatBubbleVariants, type ChatBubbleRole } from './chat-bubble.svelte';\n"
    }
  ]
}
